# Copy to .env and fill in.
PORT=8900
# Must match BMM links-config analytics_key. Generate a long random value.
API_KEY=changeme-generate-a-long-random-key
# Unlocks the in-dashboard deletion-approval panel. Keep this secret.
ADMIN_KEY=changeme-admin-secret

# GDPR retention: raw events older than this are auto-deleted (default 180 days).
RETENTION_DAYS=180
# Mandatory review delay before an un-actioned erasure request auto-applies (default 72h).
DELETE_DELAY_H=72

STORAGE_LIMIT_MB=5120