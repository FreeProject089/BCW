# BMM telemetry server (Axum + Postgres)
PORT=8900
# PUBLIC ingest key — ships in the app (links-config.ts analytics_key). Only
# allows submitting telemetry, so it's safe to be public. Convention: bmm_pk_…
API_KEY=bmm_pk_change-me
# PRIVATE admin key — server-only, NEVER shipped. Approves deletions / writes
# goals (sent as X-Admin-Key). Convention: bmm_sk_…
ADMIN_KEY=bmm_sk_change-me
# Data retention; rows older than this are purged automatically
RETENTION_DAYS=180
# Mandatory review delay before a deletion request auto-applies
DELETE_DELAY_H=72
# Postgres connection (docker-compose sets this for you)
DATABASE_URL=postgres://bmm:bmm@localhost:5432/telemetry
# Static files to serve at / (the built React app, or the legacy ../public)
STATIC_DIR=public
# Anti-spam: max ingest requests per minute per client IP (token bucket → 429).
RATE_PER_MIN=240
# Max events accepted in one batch (oversized → 413).
MAX_BATCH=1000
