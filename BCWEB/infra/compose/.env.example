# Copy to .env and fill in. NEVER commit .env.
POSTGRES_USER=bcweb
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=bcweb

# 32+ random chars (openssl rand -hex 32)
JWT_SECRET=change-me-32-bytes-hex

# Object storage (MinIO defaults shown; use real S3 creds in prod)
S3_ACCESS_KEY=bcweb-minio
S3_SECRET_KEY=change-me-strong

# Public hostname Caddy serves (TLS auto). Use localhost for local dev.
SITE_DOMAIN=localhost

# Stripe (optional until hosting/billing phase)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
