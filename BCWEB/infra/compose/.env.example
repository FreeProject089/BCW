# Copy to .env and fill in. NEVER commit .env.
POSTGRES_USER=bcweb
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=bcweb

# 32+ random chars (openssl rand -hex 32)
JWT_SECRET=change-me-32-bytes-hex

# Object storage (MinIO defaults shown; use real S3 creds in prod)
S3_ACCESS_KEY=bcweb-minio
S3_SECRET_KEY=change-me-strong
S3_BUCKET=bcweb
# Public endpoint the BROWSER uses for pre-signed up/downloads (must be reachable
# from the user's machine). Local: http://localhost:9000 — Prod: https://s3.your-domain
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Caddy site address. LOCAL dev: http://localhost:5176 (plain HTTP on :5176).
# PRODUCTION: set to your bare domain (e.g. community.example.com) and Caddy
# auto-provisions HTTPS. See DOMAIN_SETUP.md for the full walkthrough.
SITE_DOMAIN=http://localhost:5176
# Full public URL (scheme + host) — used for Stripe + OAuth callback redirects.
SITE_URL=http://localhost:5176

# Stripe (hosting/billing). Get keys at dashboard.stripe.com; the webhook secret
# from `stripe listen` or the dashboard endpoint pointing at /api/hosting/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Tag Manager container id (e.g. GTM-XXXXXXX). Optional — leave blank to never
# load it. Baked into the frontend bundle at BUILD time (Vite), and even when set it
# only actually loads client-side after a visitor accepts the "Analytics" cookie
# category (see CookieConsent.jsx / gtm.js) — matches the promise made on /cookies.
VITE_GTM_ID=

# OAuth "Continue with…" login/signup. Leave a provider's pair blank to hide its
# button entirely (see GET /auth/oauth/providers). Register an OAuth app at:
#   GitHub:  github.com/settings/developers  → callback: <SITE_URL>/api/auth/oauth/github/callback
#   Discord: discord.com/developers/applications → OAuth2 → redirect: <SITE_URL>/api/auth/oauth/discord/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# BMM telemetry dashboard (served at TELEMETRY_DOMAIN, default http://telemetry.localhost).
# The dashboard is PRIVATE: enter ADMIN_KEY in its unlock screen to view data.
# API_KEY is what the BMM app uses to send telemetry. Change both before production.
TELEMETRY_ADMIN_KEY=change-me-admin
TELEMETRY_API_KEY=change-me
# Public hostname for the telemetry dashboard. Local: http://telemetry.localhost
TELEMETRY_DOMAIN=http://telemetry.localhost
DISCORD_TOKEN=